APP_ENV=dev
WEB_APP_PORT=8000
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
OIDC_AUTHORITY_URL=https://login.microsoftonline.com/your-tenant-id/v2.0
OIDC_CALLBACK_URL_TEST=http://localhost:8000/auth/callback
OIDC_CALLBACK_URL_PROD=https://your-webapp.azurewebsites.net/auth/callback
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=your-database
OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
OPENAI_API_VERSION=2024-10-21
OPENAI_DEPLOYMENT=gpt-4o-mini
GOOGLE_NEWS_RSS_BASE_URL=https://news.google.com/rss/search
SQL_MAX_ROWS=100
MOCK_AUTH_ENABLED=false

# Azure Web App production deployment profile
PROD_APP_ENV=production
PROD_APP_BASE_URL=https://your-webapp.azurewebsites.net
PROD_MOCK_AUTH_ENABLED=false
PROD_APP_STARTUP_COMMAND=python -m app.main
PROD_SMOKE_MAX_RETRIES=60
PROD_SMOKE_RETRY_INTERVAL_SEC=10
PROD_ACR_LOGIN_SERVER=your-registry.azurecr.io
PROD_CONTAINER_IMAGE_REPOSITORY=your-image-repository
PROD_CONTAINER_IMAGE_TAG=

AZ_SUBSCRIPTION_ID=your-subscription-id
AZ_RESOURCE_GROUP=your-resource-group
AZ_LOCATION=canadaeast
AZ_APP_SERVICE_PLAN=your-app-service-plan
AZ_APP_SERVICE_SKU=B1
AZ_WEBAPP_NAME=your-webapp-name
APP_BASE_URL=https://your-webapp.azurewebsites.net

AZ_DEPLOY_TENANT_ID=your-deploy-tenant-id
AZ_DEPLOY_CLIENT_ID=your-deploy-client-id
AZ_DEPLOY_CLIENT_SECRET=your-deploy-client-secret

APP_STARTUP_COMMAND=python -m app.main
SMOKE_MAX_RETRIES=60
SMOKE_RETRY_INTERVAL_SEC=10
